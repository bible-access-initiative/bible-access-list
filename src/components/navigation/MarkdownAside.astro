---
// TableOfContents.astro
export interface Props {
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { headings } = Astro.props;
---

<aside class="sticky top-8 hidden lg:block w-64 max-h-[calc(100vh-4rem)] overflow-y-auto">
  <nav class="space-y-1" id="toc-nav">
    <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-4 uppercase tracking-wide">
      On this page
    </h2>
    {headings.map((heading) => (
      <a
        href={`#${heading.slug}`}
        data-slug={heading.slug}
        class={`
          toc-link block transition-all duration-200 border-l-2
          ${heading.depth === 1 ? 'pl-4' : ''}
          ${heading.depth === 2 ? 'pl-8' : ''}
          ${heading.depth === 3 ? 'pl-12' : ''}
          text-sm leading-6
          text-gray-600 dark:text-gray-400 
          border-gray-200 dark:border-gray-700
          hover:text-gray-900 hover:dark:text-gray-100
          hover:border-gray-400 dark:hover:border-gray-500
        `}
      >
        {heading.text}
      </a>
    ))}
  </nav>
</aside>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.documentElement;
    const tocLinks = document.querySelectorAll('.toc-link');

    const headingSlugs = Array.from(tocLinks).map(l => l.getAttribute('data-slug'));
    const headingElements = new Map();
    headingSlugs.forEach(slug => {
      if (!slug) return;
      const el = document.getElementById(slug);
      if (el) headingElements.set(slug, el);
    });

    let currentActiveSlug = null;
    let io = null;
    let isAutoScrolling = false;
    let pendingSlug = null;

    // --- Header offset helpers --------------------------------------
    function getHeaderOffset() {
      const header = document.querySelector('header'); // adjust selector if needed
      const h = header ? Math.round(header.getBoundingClientRect().height) : 0;
      const buffer = 8;
      return (h || 72) + buffer;
    }

    function setHeaderOffsetVar() {
      root.style.setProperty('--header-offset', `${getHeaderOffset()}px`);
      refreshObserver(); // keep IO's rootMargin in sync with the new offset
    }

    function getOffsetFromVar() {
      const v = getComputedStyle(root).getPropertyValue('--header-offset').trim();
      const n = parseInt(v.replace('px',''), 10);
      return Number.isFinite(n) ? n : 0;
    }

    function createObserver() {
      const opts = {
        rootMargin: `-${getOffsetFromVar() + 1}px 0px -70% 0px`,
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const slug = entry.target.id;

          // During auto scroll, only accept the intended section
          if (isAutoScrolling && pendingSlug && slug !== pendingSlug) return;
          setActiveLink(slug);
        });
      }, opts);

      return observer;
    }

    function refreshObserver() {
      if (io) io.disconnect();
      io = createObserver();
      headingElements.forEach((el) => io.observe(el));
    }

    function setActiveLink(slug) {
      if (!slug || currentActiveSlug === slug) return;

      tocLinks.forEach(link => {
        link.classList.remove(
          'text-blue-600', 'dark:text-blue-400',
          'border-blue-600', 'dark:border-blue-400',
          'font-medium'
        );
        link.classList.add(
          'text-gray-600', 'dark:text-gray-400',
          'border-gray-200', 'dark:border-gray-700'
        );
      });

      const activeLink = document.querySelector(`[data-slug="${slug}"]`);
      if (activeLink) {
        activeLink.classList.remove(
          'text-gray-600', 'dark:text-gray-400',
          'border-gray-200', 'dark:border-gray-700'
        );
        activeLink.classList.add(
          'text-blue-600', 'dark:text-blue-400',
          'border-blue-600', 'dark:border-blue-400',
          'font-medium'
        );

        const aside = activeLink.closest('aside');
        if (aside) {
          const linkRect = activeLink.getBoundingClientRect();
          const asideRect = aside.getBoundingClientRect();
          if (linkRect.top < asideRect.top + 100 || linkRect.bottom > asideRect.bottom - 50) {
            activeLink.scrollIntoView({ block: 'center', behavior: 'smooth' });
          }
        }
      }

      currentActiveSlug = slug;
    }

    function scrollToSlug(slug, replaceHistory = false) {
      const target = document.getElementById(slug);
      if (!target) return;

      pendingSlug = slug;
      setActiveLink(slug);

      const offset = getHeaderOffset();
      const firstTop = target.getBoundingClientRect().top + window.scrollY - offset;

      isAutoScrolling = true;
      window.scrollTo({ top: firstTop, behavior: 'smooth' });

      const newHash = `#${slug}`;
      if (replaceHistory) history.replaceState(null, '', newHash);
      else history.pushState(null, '', newHash);

      setTimeout(() => {
        const newOffset = getHeaderOffset();
        const desiredTop = target.getBoundingClientRect().top + window.scrollY - newOffset;
        const delta = Math.abs(desiredTop - window.scrollY);
        if (delta > 1) {
          window.scrollTo({ top: desiredTop, behavior: 'auto' });
        }
        setTimeout(() => {
          isAutoScrolling = false;
          pendingSlug = null;
        }, 50);
      }, 250);
    }

    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.getAttribute('data-slug');
        if (slug) scrollToSlug(slug, false);
      });
    });

    setHeaderOffsetVar();
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(setHeaderOffsetVar, 120);
    });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(setHeaderOffsetVar).catch(() => {});
    }

    if (window.location.hash) {
      const initialSlug = decodeURIComponent(window.location.hash.slice(1));
      window.addEventListener('load', () => {
        scrollToSlug(initialSlug, true);
        setActiveLink(initialSlug);
      });
    } else {
      refreshObserver();
      setTimeout(() => {
        if (!currentActiveSlug && headings && headings.length) {
          const first = headings[0]?.slug;
          if (first) setActiveLink(first);
        }
      }, 100);
    }
  });
</script>

<style>
  :global(:root) {
    --header-offset: 80px;
  }

  :global(.prose :where(h1,h2,h3,h4,h5,h6)[id]) {
    scroll-margin-top: var(--header-offset);
  }
  aside::-webkit-scrollbar { width: 4px; }
  aside::-webkit-scrollbar-track { background: transparent; }
  aside::-webkit-scrollbar-thumb { background: rgb(203 213 225); border-radius: 2px; }
  aside::-webkit-scrollbar-thumb:hover { background: rgb(148 163 184); }

  /* Dark mode scrollbar */
  :global(.dark) aside::-webkit-scrollbar-thumb { background: rgb(51 65 85); }
  :global(.dark) aside::-webkit-scrollbar-thumb:hover { background: rgb(71 85 105); }
</style>
