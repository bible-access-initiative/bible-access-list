---
// LightDarkMode.astro
// Props (optional customization)
export interface Props {
    class?: string;
    id?: string;
}

const { class: className = "", id = "DarkModeToggle" } = Astro.props;
---

<button
        id={id}
        type="button"
        aria-label="Toggle between Dark and Light mode"
        class:list={[
            "relative inline-flex h-6 w-10 mx-1 flex-shrink-0 cursor-pointer rounded-full border",
            "transition-colors duration-200 ease-in-out shadow-inner",
            "bg-gray-200 border-gray-400 hover:bg-gray-400 dark:bg-stone-600 dark:hover:bg-stone-500",
            className
        ]}
        role="switch"
        data-aw-toggle-color-scheme>

    <span class="sr-only">Toggle dark mode</span>

    <!-- Toggle Circle/Slider - Pure Tailwind Animation -->
    <span
            id={`${id}Space`}
            class="pointer-events-none relative inline-block h-6 w-6 transform rounded-full shadow ring-0
               transition-transform duration-200 ease-in-out translate-x-0 dark:translate-x-4 bg-white dark:bg-stone-900">

        <!-- Moon Icon (Dark Mode) -->
        <span
                id={`${id}MoonWrap`}
                aria-hidden="true"
                class="absolute inset-0 flex h-6 w-6 border rounded-full items-center justify-center
                   opacity-0 dark:opacity-100 transition-opacity duration-200 ease-in">
            <svg xmlns="http://www.w3.org/2000/svg" fill="#fff" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 15a9.72 9.72 0 0 1-3.75.75 9.75 9.75 0 0 1-9-13.5 9.75 9.75 0 0 0-6 9A9.75 9.75 0 0 0 12.75 21a9.75 9.75 0 0 0 9-6Z"/>
            </svg>
        </span>

        <!-- Sun Icon (Light Mode) - Yellow -->
        <span
                id={`${id}SunWrap`}
                aria-hidden="true"
                class="absolute inset-0 flex h-6 w-6 border border-yellow-300 rounded-full items-center justify-center
                   opacity-100 dark:opacity-0 transition-opacity duration-200 ease-out scale-110">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5 scale-110">
                <g fill="none" stroke="#F59E0B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <!-- Sun center circle -->
                    <circle cx="12" cy="12" r="4" fill="#FCD34D"/>
                    <!-- Sun rays -->
                    <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </g>
            </svg>
        </span>
    </span>
</button>

<script is:inline>
    // Dark mode toggle functionality for Astro (client-side only)
    (function() {
        const STORAGE_KEY = 'theme-preference';

        // Get theme preference
        function getColorPreference() {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) {
                return stored;
            }
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        // Apply theme to document
        function reflectPreference(theme) {
            // Apply theme class to html element
            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // Update button aria-label
            const buttons = document.querySelectorAll('[data-aw-toggle-color-scheme]');
            buttons.forEach(button => {
                button.setAttribute('aria-label',
                    theme === 'light' ? 'Switch to dark mode' : 'Switch to light mode'
                );
                button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
            });
        }

        // Save preference and apply
        function setPreference(theme) {
            localStorage.setItem(STORAGE_KEY, theme);
            reflectPreference(theme);
        }

        // Toggle theme
        function toggleTheme() {
            const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            const newTheme = currentTheme === 'light' ? 'dark' : 'light';
            setPreference(newTheme);
        }

        // Initialize theme on page load
        function initializeTheme() {
            const theme = getColorPreference();
            reflectPreference(theme);
        }

        // Set initial theme immediately to prevent flash
        initializeTheme();

        // Setup event listeners when DOM is ready
        function setupEventListeners() {
            const awButtons = document.querySelectorAll('[data-aw-toggle-color-scheme]');
            awButtons.forEach(button => {
                // Remove any existing listeners to prevent duplicates
                button.removeEventListener('click', toggleTheme);
                // Add the listener
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    toggleTheme();
                });
            });
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', setupEventListeners);
        } else {
            setupEventListeners();
        }

        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: dark)')
            .addEventListener('change', ({ matches: isDark }) => {
                // Only update if user hasn't manually set a preference
                if (!localStorage.getItem(STORAGE_KEY)) {
                    const theme = isDark ? 'dark' : 'light';
                    reflectPreference(theme);
                }
            });

        // Re-initialize on page navigation (for SPAs)
        document.addEventListener('astro:page-load', function() {
            initializeTheme();
            setupEventListeners();
        });
    })();
</script>

<style>
/* Set initial theme before page load to prevent flash */
:root {
    color-scheme: light;
    }

.dark {
    color-scheme: dark;
    }
</style>