---
import { LocalePath } from '~/utils/StaticPathHelper';
export function getStaticPaths() {return LocalePath();}

import Layout from "~/layouts/PageLayout.astro"
import i18n from '~/components/i18n/index.js';
import { getLanguageFromPath, SITE } from '~/config.js'
import FrontPageMap from '~/components/map/FrontPageMap.astro';
 
const locale = getLanguageFromPath(Astro.url)
const t = i18n[locale]
const {content} = Astro.props

---

<main class="grid min-h-full place-items-center bg-white px-6 py-24 sm:py-32 lg:px-8">
	<div class="text-center">
	  <p class="text-base font-semibold text-indigo-600"></p>
	  <h1 class="mt-4 text-5xl font-semibold tracking-tight text-balance text-gray-900 sm:text-7xl">Coming Soon</h1>
	  <p class="mt-6 text-lg font-medium text-pretty text-gray-500 sm:text-xl/8">Launching in 2025</p>
	</div>
  </main>
